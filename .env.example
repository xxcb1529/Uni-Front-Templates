# 复制为 .env.development / .env.production 或 .env.local 后按需修改（.env.local 已被 gitignore）

# API 根地址（与 Vite 一致使用 VITE_ 前缀）
VITE_API_BASE_URL=https://pcapi-xiaotuxian-front-devtest.itheima.net

# 业务成功码（逗号分隔多个，默认仅 1）
VITE_API_SUCCESS_CODE=1

# 是否在 Authorization 前加 Bearer 前缀（true / false）
VITE_API_AUTH_BEARER=false

# 客户端标识请求头（可被网关统计；历史接口若写死旧 key 可改此处）
VITE_API_SOURCE_HEADER_KEY=source-client
VITE_API_SOURCE_HEADER_VALUE=miniapp
